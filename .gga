# Gentleman Guardian Angel Configuration
# Local compact review config for AlbumSL.

# AI Provider
# Options: claude, gemini, codex, opencode, ollama:<model>, lmstudio[:model], github:<model>
PROVIDER="codex"

# File patterns to include in review.
FILE_PATTERNS="*.ts,*.tsx,*.js,*.jsx"

# File patterns to exclude from review.
EXCLUDE_PATTERNS="*.test.ts,*.spec.ts,*.test.tsx,*.spec.tsx,*.d.ts"

# Compact rules file to reduce token usage.
RULES_FILE=".gga-rules.md"

# Strict mode: fail if AI response is ambiguous.
STRICT_MODE="true"

# Timeout in seconds for AI provider response.
TIMEOUT="300"

# Base branch for --pr-mode.
# PR_BASE_BRANCH="master"
